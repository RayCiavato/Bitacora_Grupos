APP_DOMAIN=localhost

POSTGRES_DB=bitacora
POSTGRES_USER=bitacora_user
POSTGRES_PASSWORD=change_this_db_password

JWT_SECRET=change_this_jwt_secret_with_at_least_32_chars
JWT_EXPIRES_IN=12h
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
JWT_ISSUER=bitacora-api
JWT_AUDIENCE=bitacora-clients
AUTH_COOKIE_NAME=bitacora_access
REFRESH_COOKIE_NAME=bitacora_refresh
COOKIE_DOMAIN=
COOKIE_SECURE=true
COOKIE_SAMESITE=strict

ADMIN_DEFAULT_NAME=Administrador
ADMIN_DEFAULT_EMAIL=admin@bitacora.local
ADMIN_DEFAULT_PASSWORD=ChangeThisAdminPassword!123

MAX_FAILED_ATTEMPTS=5
LOCK_MINUTES=15
PASSWORD_MIN_LENGTH=12
MFA_REQUIRED=false
ALLOW_PUBLIC_REGISTRATION=false
UPLOAD_DIR=/usr/src/app/uploads
UPLOAD_MAX_BYTES=10485760

REMINDER_ENABLED=false
REMINDER_CRON=0 17 * * 1-5
REMINDER_TIMEZONE=America/Bogota
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_this_grafana_password
